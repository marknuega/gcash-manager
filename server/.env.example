# Copy to server/.env and fill in. server/.env is git-ignored.

# Postgres connection string. For Neon it looks like:
#   postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/gcash?sslmode=require
DATABASE_URL=

# Any long random text. Must stay constant — if it changes everyone is logged out.
JWT_SECRET=

# Password given to the seeded owner/admin account (db:seed). Change it after first login.
SEED_ADMIN_PASSWORD=admin123
